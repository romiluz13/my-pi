{
  "npmCommand": [
    "mise",
    "exec",
    "node@24",
    "--",
    "npm"
  ],
  "lastChangelogVersion": "0.80.6",
  "defaultProvider": "grove-openai",
  "defaultModel": "FW-GLM-5.2",
  "observational-memory": {
    "observeAfterTokens": 10000,
    "reflectAfterTokens": 20000,
    "compactAfterTokens": 81000,
    "compactAfterTokensMode": "ratio",
    "compactAfterTokensRatio": 0.4,
    "observationsPoolMaxTokens": 20000,
    "agentMaxTurns": 16,
    "model": {
      "provider": "grove-openai",
      "id": "gpt-5.4-mini",
      "thinking": "off"
    },
    "passive": false,
    "debugLog": false
  },
  "theme": "dark",
  "packages": [
    "npm:@spences10/pi-context",
    "npm:@juicesharp/rpiv-ask-user-question",
    "npm:@narumitw/pi-statusline",
    "npm:pi-btw",
    "npm:pi-hermes-memory",
    "npm:pi-intercom",
    "npm:@spences10/pi-observability",
    "npm:pi-lens",
    "npm:pi-observational-memory",
    "npm:pi-prompt-template-model",
    "npm:pi-rewind",
    "npm:pi-subagents",
    "npm:pi-web-access"
  ],
  "defaultThinkingLevel": "xhigh",
  "subagents": {
    "agentOverrides": {
      "worker": {
        "thinking": "xhigh"
      },
      "planner": {
        "thinking": "xhigh"
      },
      "oracle": {
        "thinking": "xhigh"
      },
      "reviewer": {
        "thinking": "xhigh"
      },
      "researcher": {
        "thinking": "xhigh"
      },
      "context-builder": {
        "thinking": "xhigh"
      },
      "scout": {
        "thinking": "xhigh"
      },
      "delegate": {
        "thinking": "xhigh"
      }
    }
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 65536,
    "keepRecentTokens": 50000
  },
  "defaultProjectTrust": "ask",
  "enabledModels": [
    "claude-*",
    "gpt-5.4",
    "gpt-5.4-mini",
    "grok-*",
    "kimi-*",
    "deepseek-*",
    "FW-GLM-*",
    "FW-MiniMax-*",
    "FW-Kimi-*",
    "FW-DeepSeek-*"
  ],
  "externalEditor": "code --wait",
  "treeFilterMode": "no-tools",
  "branchSummary": {
    "skipPrompt": true
  },
  "retry": {
    "enabled": true,
    "maxRetries": 10,
    "baseDelayMs": 2000,
    "provider": {
      "timeoutMs": 300000,
      "maxRetries": 0,
      "maxRetryDelayMs": 60000
    }
  }
}
